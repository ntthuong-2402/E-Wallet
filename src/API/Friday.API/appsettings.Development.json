{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "SerilogClassic": {
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "FridayDb": "Host=localhost;Port=5432;Database=friday;Username=friday;Password=friday;Timeout=15",
    "AdminDatabase": "Host=localhost;Port=5432;Database=friday;Username=friday;Password=friday;Timeout=15",
    "Redis": "localhost:6379"
  },
  "Cache": {
    "UseRedis": false,
    "RedisConnectionString": "localhost:6379"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "Friday.API",
    "LogExport": "Serilog",
    "OtlpEndpoint": "http://127.0.0.1:4317",
    "OtlpProtocol": "Grpc"
  },
  "Localization": {
    "CacheMinutes": 60
  },
  "Authentication": {
    "AllowPublicRegistration": true
  }
}
