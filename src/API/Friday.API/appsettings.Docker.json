{
  "ConnectionStrings": {
    "FridayDb": "Host=postgres;Port=5432;Database=friday;Username=friday;Password=friday",
    "AdminDatabase": "Host=postgres;Port=5432;Database=friday;Username=friday;Password=friday",
    "Redis": "redis:6379"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ApplyMigrationsOnStartup": true
  },
  "Cache": {
    "UseRedis": true,
    "RedisConnectionString": "redis:6379",
    "RedisInstanceName": "Friday:"
  },
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "Friday.API",
    "OtlpEndpoint": "http://jaeger:4317"
  },
  "Authentication": {
    "AllowPublicRegistration": true
  },
  "SerilogClassic": {
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}
